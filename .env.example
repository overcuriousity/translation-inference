API_BASE_URL=https://llm.mikoshi.de
API_KEY=your-api-key-here

# Default models to use if none selected in UI
TRANSLATION_MODEL=gpgpu/qwen3:14b-q5_k_m-32768
WHISPER_MODEL=gpgpu/whisper

# Optional: Manual model lists (comma-separated IDs)
# If empty, the server will try to auto-populate from the provider API
TRANSLATION_MODELS=gpgpu/qwen3:14b-q5_k_m-32768,deepseek-chat
WHISPER_MODELS=gpgpu/whisper

LISTEN_ADDR=0.0.0.0:3000

# Optional: Gated tier — a second backend protected by an access key.
# Users must enter GATED_ACCESS_KEY in the UI to unlock this tier.
# The actual LLM credentials (GATED_API_BASE_URL, GATED_API_KEY) stay server-side.
# All three must be set for the gated tier to be enabled.
# GATED_API_BASE_URL=https://premium-llm.example.com
# GATED_API_KEY=your-gated-backend-key
# GATED_ACCESS_KEY=shared-password-for-users

# Optional: TTS (text-to-speech) — enables the speaker button in the output and source panels.
# Point at any OpenAI-compatible /v1/audio/speech endpoint.
# Recommended for self-hosted TTS: speaches-ai (https://speaches.ai) with the
# Kokoro-82M-v1.0-ONNX model, which natively supports en, es, fr, hi, it, ja, pt, zh.
# All other languages (de, nl, pl, ru, ko, ar, ...) fall back to TTS_VOICE.
# TTS_API_BASE_URL is the base URL of the TTS endpoint (no trailing slash).
# TTS_MODEL: model ID your endpoint expects.
# TTS_VOICE: default voice — used for languages not in TTS_VOICE_MAP.
# TTS_CHUNK_SIZE: max bytes per synthesis request. Leave unset/0 for no chunking
#   (recommended for local models). Set to 4000 to match the OpenAI API limit.
# TTS_VOICE_MAP: per-language voice overrides — comma-separated lang:voice pairs.
#   The frontend sends ISO 639-1 codes (en, fr, ja, zh, ...) as the language key.
#
# Full Kokoro-82M-v1.0-ONNX voice list (speaches-ai):
# Voices marked [OK] are confirmed working with the phonemizer/espeak backend.
# Chinese voices [BROKEN] crash because Kokoro passes lang code "zh" to espeak,
# but espeak expects "cmn" for Mandarin — a speaches-ai bug, not a config issue.
#
#   English US (en)  [OK]
#     female: af_heart, af_alloy, af_aoede, af_bella, af_jessica, af_kore,
#             af_nicole, af_nova, af_river, af_sarah, af_sky
#     male:   am_adam, am_echo, am_eric, am_fenrir, am_liam, am_michael,
#             am_onyx, am_puck, am_santa
#   English GB (en — alternative, select via TTS_VOICE_MAP if preferred)  [OK]
#     female: bf_alice, bf_emma, bf_isabella, bf_lily
#     male:   bm_daniel, bm_fable, bm_george, bm_lewis
#   Spanish (es)  [OK]
#     female: ef_dora
#     male:   em_alex, em_santa
#   French (fr)  [OK]
#     female: ff_siwis
#   Hindi (hi)  [OK]
#     female: hf_alpha, hf_beta
#     male:   hm_omega, hm_psi
#   Italian (it)  [OK]
#     female: if_sara
#     male:   im_nicola
#   Japanese (ja)  [OK]
#     female: jf_alpha, jf_gongitsune, jf_nezumi, jf_tebukuro
#     male:   jm_kumo
#   Portuguese BR (pt)  [OK]
#     female: pf_dora
#     male:   pm_alex, pm_santa
#   Chinese (zh / zh-TW)  [BROKEN — espeak/phonemizer incompatibility, omit from map]
#     female: zf_xiaobei, zf_xiaoni, zf_xiaoxiao, zf_xiaoyi
#     male:   zm_yunjian, zm_yunxi, zm_yunxia, zm_yunyang
#
# TTS_API_BASE_URL=http://tts.example.com
# TTS_API_KEY=your-tts-api-key-here
# TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX-fp16
# TTS_VOICE=af_heart
# TTS_CHUNK_SIZE=0
# TTS_VOICE_MAP=en:af_heart,es:ef_dora,fr:ff_siwis,hi:hf_alpha,it:if_sara,ja:jf_alpha,pt:pf_dora

# Optional: Bitvault integration — enables "Save to Bitvault" buttons in the UI
# and allows preloading source text via the ?from=<raw-url> query parameter.
# BITVAULT_URL must point to the root of your Bitvault instance (no trailing slash).
# BITVAULT_API_KEY is optional; only needed if your instance requires authentication.
# BITVAULT_URL=https://paste.example.com
# BITVAULT_API_KEY=your-bitvault-api-key-here
