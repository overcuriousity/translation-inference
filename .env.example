API_BASE_URL=https://llm.mikoshi.de
API_KEY=your-api-key-here

# Default models to use if none selected in UI
TRANSLATION_MODEL=gpgpu/qwen3:14b-q5_k_m-32768
WHISPER_MODEL=gpgpu/whisper

# Optional: Manual model lists (comma-separated IDs)
# If empty, the server will try to auto-populate from the provider API
TRANSLATION_MODELS=gpgpu/qwen3:14b-q5_k_m-32768,deepseek-chat
WHISPER_MODELS=gpgpu/whisper

LISTEN_ADDR=0.0.0.0:3000

# Optional: Gated tier — a second backend protected by an access key.
# Users must enter GATED_ACCESS_KEY in the UI to unlock this tier.
# The actual LLM credentials (GATED_API_BASE_URL, GATED_API_KEY) stay server-side.
# All three must be set for the gated tier to be enabled.
# GATED_API_BASE_URL=https://premium-llm.example.com
# GATED_API_KEY=your-gated-backend-key
# GATED_ACCESS_KEY=shared-password-for-users

# ── TTS (text-to-speech) ─────────────────────────────────────────────────────
# Enables speaker buttons in the source and output panels.
# Point TTS_API_BASE_URL at any OpenAI-compatible /v1/audio/speech endpoint.
#
# TTS_VOICE_MAP  (sole TTS configuration)
#   Comma-separated entries, one per language.  Format: lang:voice@model
#   • lang   — ISO 639-1 code matching the frontend language selector
#               (use zh-TW for Traditional Chinese, zh for Simplified Chinese)
#   • voice  — voice ID passed to the model's `voice` field (model-specific)
#   • @model — model ID as registered at your API provider (required)
#
#   Languages listed here get TTS buttons in the UI; unlisted languages do not.
#   Requests for an unlisted language return HTTP 400.
#
# TTS_CHUNK_SIZE
#   Max bytes per synthesis request.  0 / unset = no chunking (recommended for
#   local models).  Set to 4000 to match the OpenAI hosted-API limit.
#
# ── Voice reference for the gpgpu/tts model ──────────────────────────────────
#
#  The voice field selects both engine and speaker:
#
#  Kokoro voices — English + Chinese (kokoro-multi-lang-v1_1)
#  ─────────────────────────────────────────────────────────────────────────────
#  English US ♀  af_heart · af_alloy · af_aoede · af_bella · af_jessica · af_kore
#                af_nicole · af_nova · af_river · af_sarah · af_sky
#  English US ♂  am_adam · am_echo · am_eric · am_fenrir · am_liam · am_michael
#                am_onyx · am_puck · am_santa
#  English GB ♀  bf_alice · bf_emma · bf_isabella · bf_lily
#  English GB ♂  bm_daniel · bm_fable · bm_george · bm_lewis
#  Chinese       numeric speaker ID string: "50"–"102" (♀ e.g. "54", ♂ e.g. "60")
#
#  Full EN voice samples: https://huggingface.co/hexgrad/Kokoro-82M#voices
#
#  Piper voices — ISO 639-1 code as voice ID (one speaker per language)
#  ─────────────────────────────────────────────────────────────────────────────
#  ar · cs · da · de · el · es · fi · fr · hi · hu · id · it
#  nl · no · pl · pt · ro · ru · sv · tr · uk · vi
#
#  No TTS available: bg (Bulgarian) · ja (Japanese) · ko (Korean)
#  (No suitable open-weight model exists for these languages at this time.)
# ─────────────────────────────────────────────────────────────────────────────
#
# TTS_API_BASE_URL=https://llm.mikoshi.de
# TTS_API_KEY=your-api-key-here
# TTS_CHUNK_SIZE=0
# TTS_VOICE_MAP=en:af_heart@gpgpu/tts,de:de@gpgpu/tts,fr:fr@gpgpu/tts,es:es@gpgpu/tts,it:it@gpgpu/tts,pt:pt@gpgpu/tts,nl:nl@gpgpu/tts,pl:pl@gpgpu/tts,ru:ru@gpgpu/tts,zh:54@gpgpu/tts,zh-TW:54@gpgpu/tts,ar:ar@gpgpu/tts,tr:tr@gpgpu/tts,uk:uk@gpgpu/tts,cs:cs@gpgpu/tts,sv:sv@gpgpu/tts,da:da@gpgpu/tts,fi:fi@gpgpu/tts,no:no@gpgpu/tts,ro:ro@gpgpu/tts,hu:hu@gpgpu/tts,el:el@gpgpu/tts,hi:hi@gpgpu/tts,vi:vi@gpgpu/tts,id:id@gpgpu/tts

# ── Translation quality tuning ────────────────────────────────────────────────
# DEFAULT_CONTEXT_SIZE
#   Fallback context window size (tokens) used when the model ID does not
#   encode one.  Default: 4096 (conservative).  Increase if you use a model
#   that has a larger context but whose ID does not include the size number.
# DEFAULT_CONTEXT_SIZE=4096

# INPUT_TOKEN_RATIO
#   Fraction of usable tokens (after overhead) allocated to the *input*.
#   The remainder is reserved for the model's output.  Default: 0.5 (50/50).
#   For compact→verbose language pairs (e.g. Chinese→German) try 0.4 to give
#   more headroom to the output and reduce mid-sentence truncation.
# INPUT_TOKEN_RATIO=0.5

# CJK_CHARS_PER_TOKEN / LATIN_CHARS_PER_TOKEN
#   Script-aware chars-per-token estimates.  The chunker blends these based on
#   how much CJK text is detected in the input.  Defaults: 1.5 / 4.0.
#   Adjust if you see over- or under-chunking for a specific script.
# CJK_CHARS_PER_TOKEN=1.5
# LATIN_CHARS_PER_TOKEN=4.0

# MIN_OUTPUT_RATIO
#   Warn when the translated output is shorter than this fraction of the input
#   (char count).  Helps detect accidental summarisation.  Default: 0.3.
#   Set to 0.0 to disable the warning.
# MIN_OUTPUT_RATIO=0.3

# Optional: Bitvault integration — enables "Save to Bitvault" buttons in the UI
# and allows preloading source text via the ?from=<raw-url> query parameter.
# BITVAULT_URL must point to the root of your Bitvault instance (no trailing slash).
# BITVAULT_API_KEY is optional; only needed if your instance requires authentication.
# BITVAULT_URL=https://paste.example.com
# BITVAULT_API_KEY=your-bitvault-api-key-here
