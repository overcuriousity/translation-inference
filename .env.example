API_BASE_URL=https://llm.mikoshi.de
API_KEY=your-api-key-here

# Default models to use if none selected in UI
TRANSLATION_MODEL=gpgpu/qwen3:14b-q5_k_m-32768
WHISPER_MODEL=gpgpu/whisper

# Optional: Manual model lists (comma-separated IDs)
# If empty, the server will try to auto-populate from the provider API
TRANSLATION_MODELS=gpgpu/qwen3:14b-q5_k_m-32768,deepseek-chat
WHISPER_MODELS=gpgpu/whisper

LISTEN_ADDR=0.0.0.0:3000

# Optional: Gated tier — a second backend protected by an access key.
# Users must enter GATED_ACCESS_KEY in the UI to unlock this tier.
# The actual LLM credentials (GATED_API_BASE_URL, GATED_API_KEY) stay server-side.
# All three must be set for the gated tier to be enabled.
# GATED_API_BASE_URL=https://premium-llm.example.com
# GATED_API_KEY=your-gated-backend-key
# GATED_ACCESS_KEY=shared-password-for-users

# ── TTS (text-to-speech) ─────────────────────────────────────────────────────
# Enables speaker buttons in the source and output panels.
# Point TTS_API_BASE_URL at any OpenAI-compatible /v1/audio/speech endpoint.
#
# TTS_VOICE_MAP  (sole TTS configuration — TTS_MODEL / TTS_VOICE are removed)
#   Comma-separated entries, one per language.  Format: lang:voice@model
#   • lang   — ISO 639-1 code matching the frontend language selector
#               (use zh-TW for Traditional Chinese, zh for Simplified Chinese)
#   • voice  — voice ID passed to the model's `voice` field (model-specific)
#   • @model — model ID as registered at your API provider (required)
#
#   Languages listed here get TTS buttons in the UI; unlisted languages do not.
#   Requests for an unlisted language return HTTP 400.
#
# TTS_CHUNK_SIZE
#   Max bytes per synthesis request.  0 / unset = no chunking (recommended for
#   local models).  Set to 4000 to match the OpenAI hosted-API limit.
#
# ── gpgpu/tts voice reference ────────────────────────────────────────────────
#
#  Piper voices (named, one speaker per language)
#  ─────────────────────────────────────────────────────────────────────────────
#  de   "de"   German (de_DE-thorsten-medium)
#  en   "en"   English (en_US-lessac-medium, Piper quality)
#
#  Kokoro voices (named, English — same IDs as hexgrad/Kokoro-82M)
#  Full list: https://huggingface.co/hexgrad/Kokoro-82M#voices
#  ─────────────────────────────────────────────────────────────────────────────
#  ♀ US  af_heart · af_alloy · af_aoede · af_bella · af_jessica · af_kore
#        af_nicole · af_nova · af_river · af_sarah · af_sky
#  ♂ US  am_adam · am_echo · am_eric · am_fenrir · am_liam · am_michael
#        am_onyx · am_puck · am_santa
#  ♀ GB  bf_alice · bf_emma · bf_isabella · bf_lily
#  ♂ GB  bm_daniel · bm_fable · bm_george · bm_lewis
#
#  Kokoro Chinese speakers (model: kokoro-multi-lang-v1_1, speakers 50–102)
#  No standard names — use a numeric ID, e.g. 54 ♀ or 60 ♂.
#  (Numeric IDs are specific to this deployment, not an industry standard.)
# ─────────────────────────────────────────────────────────────────────────────
#
# TTS_API_BASE_URL=https://llm.mikoshi.de
# TTS_API_KEY=your-api-key-here
# TTS_CHUNK_SIZE=0
# TTS_VOICE_MAP=en:af_heart@gpgpu/tts,de:de@gpgpu/tts,zh:54@gpgpu/tts,zh-TW:54@gpgpu/tts

# Optional: Bitvault integration — enables "Save to Bitvault" buttons in the UI
# and allows preloading source text via the ?from=<raw-url> query parameter.
# BITVAULT_URL must point to the root of your Bitvault instance (no trailing slash).
# BITVAULT_API_KEY is optional; only needed if your instance requires authentication.
# BITVAULT_URL=https://paste.example.com
# BITVAULT_API_KEY=your-bitvault-api-key-here
