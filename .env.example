#
# Recommended self-hosted option: speaches-ai (https://speaches.ai).
# speaches-ai supports two TTS backends simultaneously:
#   • Kokoro-82M  — high-quality neural voices for en, es, fr, hi, it, pt.
#   • Piper       — fast, lightweight voices for many more languages (de, ru, zh, …).
# Both backends are served from the same speaches-ai instance; TTS_VOICE_MAP
# selects the right model per language automatically.
#
# TTS_VOICE_MAP  (sole TTS configuration — TTS_MODEL / TTS_VOICE are removed)
#   Comma-separated entries, one per language.  Format: lang:voice@model
#   • lang  — ISO 639-1 code matching the frontend language selector
#              (use zh-TW for Traditional Chinese, zh for Simplified Chinese)
#   • voice — voice ID accepted by the model (see table below)
#   • @model — model ID to use for this language (required; entries without it are ignored)
#
#   Languages listed here get TTS buttons in the UI; unlisted languages do not.
#   Requests for an unlisted language return HTTP 400.
#   Kokoro voices are referenced by their short ID (af_heart, ef_dora, …).
#   Piper models are single-voice; the voice ID is part of the model name.
#
# TTS_CHUNK_SIZE
#   Max bytes per synthesis request.  0 / unset = no chunking (recommended for
#   local models).  Set to 4000 to match the OpenAI hosted-API limit.
#
# ── speaches-ai voice reference ──────────────────────────────────────────────
#
#  Kokoro-82M-v1.0-ONNX-fp16  (model: speaches-ai/Kokoro-82M-v1.0-ONNX-fp16)
#  ─────────────────────────────────────────────────────────────────────────────
#  en (US) ♀  af_heart · af_alloy · af_aoede · af_bella · af_jessica · af_kore
#             af_nicole · af_nova · af_river · af_sarah · af_sky
#  en (US) ♂  am_adam · am_echo · am_eric · am_fenrir · am_liam · am_michael
#             am_onyx · am_puck · am_santa
#  en (GB) ♀  bf_alice · bf_emma · bf_isabella · bf_lily
#  en (GB) ♂  bm_daniel · bm_fable · bm_george · bm_lewis
#  es      ♀  ef_dora          es ♂  em_alex · em_santa
#  fr      ♀  ff_siwis
#  hi      ♀  hf_alpha · hf_beta   hi ♂  hm_omega · hm_psi
#  it      ♀  if_sara          it ♂  im_nicola
#  pt (BR) ♀  pf_dora          pt ♂  pm_alex · pm_santa
#
#  Kokoro zh voices (zf_xiaobei, zm_yunjian, …) are NOT included below because
#  the speaches-ai Python library passes the bare code "zh" to espeak, which
#  expects "cmn" for Mandarin — causing a crash.  Use the Piper zh model instead.
#
#  Japanese Kokoro voices (jf_alpha, jm_kumo, …) produce broken audio because
#  espeak switches phoneme sets mid-utterance.  No Piper ja model is available
#  in speaches-ai.  Omit ja from TTS_VOICE_MAP until fixed upstream.
#
#  Piper models  (one voice per model; voice ID = speaker name in model path)
#  ─────────────────────────────────────────────────────────────────────────────
#  ar   kareem      speaches-ai/piper-ar_JO-kareem-medium
#  cs   jirka       speaches-ai/piper-cs_CZ-jirka-medium
#  da   talesyntese speaches-ai/piper-da_DK-talesyntese-medium
#  de   thorsten    speaches-ai/piper-de_DE-thorsten-high
#  el   rapunzelina speaches-ai/piper-el_GR-rapunzelina-low
#  fi   harri       speaches-ai/piper-fi_FI-harri-medium
#  hu   anna        speaches-ai/piper-hu_HU-anna-medium
#  nl   mls         speaches-ai/piper-nl_NL-mls-medium
#  no   talesyntese speaches-ai/piper-no_NO-talesyntese-medium
#  pl   darkman     speaches-ai/piper-pl_PL-darkman-medium
#  ro   mihai       speaches-ai/piper-ro_RO-mihai-medium
#  ru   ruslan      speaches-ai/piper-ru_RU-ruslan-medium
#  sv   nst         speaches-ai/piper-sv_SE-nst-medium
#  tr   dfki        speaches-ai/piper-tr_TR-dfki-medium
#  uk   lada        speaches-ai/piper-uk_UA-lada-x_low
#  zh   huayan      speaches-ai/piper-zh_CN-huayan-medium   (Simplified + Traditional)
#
#  No Piper model available for: bg (Bulgarian), ko (Korean), ja (Japanese)
# ─────────────────────────────────────────────────────────────────────────────
#
# TTS_API_BASE_URL=http://tts.example.com
# TTS_API_KEY=your-tts-api-key-here
# TTS_CHUNK_SIZE=0
